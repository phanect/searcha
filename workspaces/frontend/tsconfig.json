{
  "extends": [
    "@phanect/configs/ts/frontend",
    "@phanect/configs/ts/addons/jsx",
    "@phanect/configs/ts/addons/vite"
  ],
  "compilerOptions": {
    "paths": {
      "@root/*": [ "./*" ],
      "@src/*": [ "./src/*" ]
    }
    // TODO tmp
    , "lib": [ "ESNext", "DOM" ] // Quick fix. Investigate @phanect/configs later
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.mjs",
    "**/*.jsx"
  ],
  "exclude": [
    "./node_modules/**",
    "./dist/**"
    // tmp
    , "**/test/**"
    , "**/*.test.ts"
    , "**/example/**"
    , "**/stories/**"
  ]
}
