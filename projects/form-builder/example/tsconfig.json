{
  "extends": [
    "@phanect/configs/ts",
    "@phanect/configs/ts/addons/npm"
  ],
  "compilerOptions": {
    "importHelpers": true,
    "paths": {
      "@": [ "./*" ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.mjs",
    "**/*.jsx"
  ],
  "exclude": [
    "./node_modules",
    "./dist"
  ]
}
