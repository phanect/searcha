{
  "name": "@phanect/datasheet-monorepo",
  "version": "0.0.0",
  "description": "Convert your dataset to websites or internal wikis",
  "homepage": "https://github.com/phanect/datasheet",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/phanect/datasheet.git"
  },
  "bugs": {
    "url": "https://github.com/phanect/datasheet/issues"
  },
  "author": "Jumpei Ogawa (https://phanective.org)",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "workspaces": [
    "workspaces/*"
  ],
  "scripts": {
    "dev": "lerna exec --parallel -- pnpm run --if-present dev",
    "build": "lerna exec -- pnpm run --if-present build",
    "lint": "pnpm run --if-present lint:tsc && eslint",
    "lint:tsc": "tsc --noEmit && lerna exec --no-prefix -- tsc --noEmit",
    "fix": "eslint --fix && pnpm pkg fix",
    "test": "lerna exec --parallel -- pnpm run --if-present test",
    "storybook": "lerna exec --parallel -- pnpm run --if-present storybook",
    "build-storybook": "lerna exec --parallel -- pnpm run --if-present build-storybook",
    "target": "lerna exec --parallel -- pnpm run --if-present target",
    "deploy": "lerna exec --parallel -- pnpm run --if-present deploy",
    "adminize": "esno ./scripts/adminize.ts",
    "clean": "git clean -dX --exclude=\"!.env\" --force",
    "refresh": "pnpm run clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install && pnpm run build"
  },
  "devDependencies": {
    "@lerna-lite/cli": "^3.9.1",
    "@lerna-lite/exec": "^3.9.1",
    "@phanect/configs": "latest",
    "@phanect/lint": "latest",
    "@phanect/lint-react": "latest",
    "@types/node": "^22.5.5",
    "eslint": "^9.11.0",
    "esno": "^4.7.0",
    "firebase-admin": "^12.6.0",
    "firebase-tools": "^13.22.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=9.x"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
