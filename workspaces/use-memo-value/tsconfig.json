{
  "extends": [
    "@phanect/configs/ts/frontend",
    "@phanect/configs/ts/addons/jsx",
    "@phanect/configs/ts/addons/npm"
  ],
  "compilerOptions": {
    // TODO tmp
    "strict": false // Until type errors to prevent build are fixed
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.mjs",
    "**/*.jsx"
  ],
  "exclude": [
    "./node_modules",
    "./dist"
    // tmp
    , "**/test/**"
    , "**/*.test.ts"
    , "**/example/**"
    , "**/stories/**"
  ]
}
