{
  "$schema": "node_modules/@lerna-lite/cli/schemas/lerna-schema.json",
  "version": "0.0.0",
  "npmClient": "pnpm",
  "useWorkspaces": true,
  "command": {
    "exec": {
      "npmClient": "pnpm",
      "stream": true
    },
    "version": {
      "exact": true,
      "gitTagCommand": "ls",
      "message": "chore: %s",
      "syncWorkspaceLock": true
    }
  }
}
