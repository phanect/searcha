{
  "name": "@phanect/use-memo-value",
  "version": "1.0.1",
  "description": "Reuse the previous version of a value unless it has changed",
  "author": "Jumpei Ogawa (https://phanective.org)",
  "contributors": [
    "Jamie Kyle <jamie.kyle@discordapp.com>"
  ],
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/useMemoValue.js",
  "module": "dist/useMemoValue.module.js",
  "scripts": {
    "build": "rm -rf dist && microbundle --inline none --name useMemoValue",
    "format": "prettier --write '**'",
    "test": "TS_NODE_PROJECT=./tsconfig.test.json ava"
  },
  "dependencies": {
    "shallowequal": "^0.1.0 || ^0.2.0 || ^1.0.0"
  },
  "peerDependencies": {
    "react": "^16.8.0"
  },
  "devDependencies": {
    "@phanect/configs": "latest",
    "@testing-library/react-hooks": "^3.2.1",
    "@types/shallowequal": "^1.1.1",
    "ava": "^3.7.1",
    "husky": "^4.2.5",
    "lint-staged": "^10.1.6",
    "microbundle": "^0.11.0",
    "prettier": "^2.0.4",
    "react": "^16.13.1",
    "react-test-renderer": "^16.13.1",
    "ts-node": "^8.9.0",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*": [
      "prettier --write",
      "git add"
    ]
  },
  "ava": {
    "extensions": [
      "ts",
      "tsx"
    ],
    "require": [
      "ts-node/register"
    ]
  }
}
