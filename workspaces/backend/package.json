  "devDependencies": {
    "@phanect/configs": "latest",
    "@types/express": "^4.17.13",
    "@types/node": "^22.7.4",
    "firebase-tools": "^11.25.2",
    "google-auth-library": "^8.8.0",
    "husky": "^4.3.8",
    "js-beautify": "^1.13.0",
    "nodemon": "^2.0.12",
