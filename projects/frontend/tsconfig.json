{
  "extends": [
    "@phanect/configs/ts/frontend",
    "@phanect/configs/ts/addons/jsx",
    "@phanect/configs/ts/addons/vite"
  ],
  "compilerOptions": {
    "paths": {
      "@root/*": [ "./*" ],
      "@src/*": [ "./src/*" ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.mjs",
    "**/*.jsx"
  ],
  "exclude": [
    "./node_modules/**",
    "./dist/**"
  ]
}
